# Security: Set your own secrets in a local .env file (DO NOT COMMIT .env)
FERNET_KEY=your_fernet_encryption_key_here
BOT_TOKEN=your_telegram_bot_token_here

# LMS Settings
LMS_BASE_URL=https://lms.usas.edu.my
LMS_ALLOW_INSECURE_SSL=false
LMS_SSL_FALLBACK_INSECURE_ON_ERROR=true
LMS_CA_BUNDLE=

# Polling & Admin
POLL_INTERVAL_SECONDS=3600
MAX_CONCURRENCY=10
POLL_BATCH_SIZE=50
POLL_TICK_SECONDS=60
POLL_JITTER_SECONDS=600
POLL_LOCK_TTL_SECONDS=300
POLL_FAILURE_BACKOFF_MAX_SECONDS=3600
EVENT_HORIZON_DAYS=30
REMINDER_INTERVAL_SECONDS=3600
LMS_HTTP_TIMEOUT_SECONDS=60
LMS_RETRY_ATTEMPTS=2
LMS_RETRY_BACKOFF_SECONDS=0.5
REGISTER_MAX_ATTEMPTS=5
REGISTER_LOCKOUT_SECONDS=900
DAILY_LOG_HOUR=8
DAILY_LOG_MINUTE=0
ADMIN_ID=0
LOG_FILE_PATH=logs/bot.log
ACTIVITY_LOG_PATH=logs/activity.log
DB_PATH=data/lms_notifier.db
DATABASE_URL=
MIGRATION_BATCH_SIZE=500

