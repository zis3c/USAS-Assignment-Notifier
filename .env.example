# Security: Set your own secrets in a local .env file (DO NOT COMMIT .env)
FERNET_KEY=your_fernet_encryption_key_here
BOT_TOKEN=your_telegram_bot_token_here

# LMS Settings
LMS_BASE_URL=https://lms.usas.edu.my

# Google Sheets (STEM DB)
SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS=your_google_credentials_json_string_or_path_here

# Polling & Admin
POLL_INTERVAL_SECONDS=3600
MAX_CONCURRENCY=10
EVENT_HORIZON_DAYS=30
ADMIN_ID=0
LOG_FILE_PATH=logs/bot.log
DB_PATH=data/lms_notifier.db
